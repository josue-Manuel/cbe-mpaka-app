{
  "entities": {
    "Announcement": {
      "title": "Annonce de la communauté",
      "description": "Annonces officielles",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string" },
        "category": { "type": "string" },
        "author": { "type": "string" },
        "isUrgent": { "type": "boolean" }
      },
      "required": ["title", "content", "date", "author"]
    },
    "Prayer": {
      "title": "Requête de prière",
      "description": "Sujets de prière",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "author": { "type": "string" },
        "content": { "type": "string" },
        "date": { "type": "string" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "likes": { "type": "number" },
        "isUrgent": { "type": "boolean" },
        "isAnonymous": { "type": "boolean" }
      },
      "required": ["userId", "content", "date", "status"]
    },
    "Member": {
      "title": "Membre de l'église",
      "description": "Informations de profil",
      "type": "object",
      "properties": {
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "member"] },
        "status": { "type": "string", "enum": ["active", "pending", "blocked"] }
      },
      "required": ["firstName", "lastName", "role", "status"]
    }
  },
  "firestore": {
    "/announcements/{announcementId}": {
      "schema": "Announcement",
      "description": "Annonces"
    },
    "/prayers/{prayerId}": {
      "schema": "Prayer",
      "description": "Prières soumises"
    },
    "/members/{userId}": {
      "schema": "Member",
      "description": "Profils des membres"
    }
  }
}
